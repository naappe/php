{"ޏ":{"definitions":["1. ތާނައިގެ ސޯޅަވަނަ އަކުރު."],"partOfSpeech":"އިތުރު"},"ޏަކަސްތެޅުން":{"definitions":["1. (ސ.) ނަކަސްތެޅުން."],"partOfSpeech":"މަސްދަރު"},"ޏަކި":{"definitions":["1. (ސ.) ތާކުންތާކު ނުޖެހޭ ވާހަކަ."],"partOfSpeech":"ނަން"},"ޏަކިތެޅުން":{"definitions":["1. (ސ.) ތާކުންތާކު ނުޖެހޭ ވިޔާނުދާ  އަނގަތެޅުން."],"partOfSpeech":"މަސްދަރު"},"ޏާ":{"definitions":["1. ނަމަވުމުގެ އަކުރެއް.","2. އަންނާން އޮތް  ޒަމާން ދައްކަން ބޭނުންކޮށް އުޅޭ ބަހެއް. މިސާލު:  މަސައްކަތް ކުރަންޏާ މޮޅުވާނެ."],"partOfSpeech":"އިތުރު"},"ޏޭކު":{"definitions":["1. (ސ.) ސޭކު."],"partOfSpeech":"ނަން"}}