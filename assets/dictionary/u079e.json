{"ޞަނާޢީ":{"definitions":["1. މަސައްކަތްތެރިކަމާ ބެހޭ.","2. މަސައްކަތްތެރި."],"partOfSpeech":"ނަންއިތުރު"},"ޞަރީޙަ":{"definitions":["1. އޮޅުމެއްނެތި ވެފައިވާ ސާފު."],"partOfSpeech":"ނަން"},"ޞަރީޙަކަން":{"definitions":["1. އޮޅުމެއްނެތް ސާފުކަން."],"partOfSpeech":"ނަންއިތުރުގެ ނަން"},"ޞަރީޙަވުން":{"definitions":["1. އޮޅުމެއް ނާރާވަރަށް ސާފުވުން."],"partOfSpeech":"މަސްދަރު"},"ޞައްޙަކުރުން":{"definitions":["1. ކުށް ފިލުވުން.","2. އެއްޗެއް ނުވަތަ ކަމެއް  ރަނގަޅު ކުރުން.","3. ޙަޤީޤަތާ އެއްގޮތް ކުރުން."],"partOfSpeech":"މަސްދަރު"},"ޞައްޙަވުން":{"definitions":["1. ކުށްފިލުން.","2. އެއްޗެއް ނުވަތަ ކަމެއް  ރަނގަޅުވުން.","3. ޙަޤީޤަތާ އެއްގޮތްވުން."],"partOfSpeech":"މަސްދަރު"},"ޞަފަރު":{"definitions":["1. ހިޖްރީ ކަލަންޑަރުގެ ދެވަނަ މަސް.","2. މުޙައްރަމް މަހާ ވިދިގެން އަންނަމަސް.","3. ދަތުރު."],"partOfSpeech":"ނަން"},"ޞަދަޤާތް":{"definitions":["1. މާތްﷲ އަށްޓަކައި ފަޤީރުންނާއި  މިސްކީނުންނަށްދޭ އެއްޗެހި."],"partOfSpeech":"ނަން"},"ޞަދަޤާތްކުރުން":{"definitions":["1. މާތްﷲ އަށްޓަކައި ފަޤީރުންނާއި  މިސްކީނުންނަށް އެއްޗެހި ދިނުން."],"partOfSpeech":"މަސްދަރު"},"ޞަދަޤާތްދިނުން":{"definitions":["1. ޞަދަޤާތް ކުރުން."],"partOfSpeech":"މަސްދަރު"},"ޞަދުރު":{"definitions":["1. ޅެންބައިތުގެ ފުރަތަމަ ފޮޅުވަތް."],"partOfSpeech":"ނަން"},"ޞަލަވާތުމަލާފަތް":{"definitions":["1. ޞަލަވާތު ތަށި ބެހެއްޓޭވަރުގެ މަލާފަތް."],"partOfSpeech":"ނަން"},"ޞަލަވާތުތަށި":{"definitions":["1. ޞަލަވާތާއި ފާތިޙާ އާއި އެކު ކެއުންތަކުގައި  ބަތްއަޅަން ގެންގުޅޭ ބޮޑެތި ތަށި."],"partOfSpeech":"ނަން"},"ޞަލަވާތްފުޅު":{"definitions":["1. ކީރިތި ރަސޫލާގެ މައްޗަށް ކިޔެވޭ ޞަލަވާތް."],"partOfSpeech":"ނަން"},"ޞަލަވާތްލެއްވުން":{"definitions":["1. ރަޙުމަތް ލެއްވުން.","2. ފާފަ ފުއްސެވުން."],"partOfSpeech":"މަސްދަރު"},"ޞަލީބު":{"definitions":["1. ޢީސާއީން (ކްރިސްޓިޔަނުން) ގެ  މުޤައްދަސް ނިޝާން.","2. މީހުން އަރުވައި މޮހޮރު  ޖަހައިފައި ބަހައްޓައިގެން، މަރަން ބޭނުންކުރާ  ކާލިގަނޑެއް."],"partOfSpeech":"ނަން"},"ޞަޙާބީން":{"definitions":["1. އަޞްޙާބު ބޭކަލުން."],"partOfSpeech":"ނަން"},"ޞާލިޙު":{"definitions":["1. ހެޔޮލަފާމީހާ.","2. ތަޤްވާވެރިޔާ."],"partOfSpeech":"ނަންއިތުރު"},"ޞާލިޙުން":{"definitions":["1. ޞާލިޙު މިބަހުގެ ގިނަގޮތް."],"partOfSpeech":"ނަން"},"ޞިރާޠުމަގު":{"definitions":["1. (ބދ.) ސީދާ ވެގެންވާ ތެދުމަގު."],"partOfSpeech":"ނަން"},"ޞިއްޙަތު":{"definitions":["1. ދުޅަހެއި.","2. ގަދަވެ ސަލާމަތުން ހުންނަ  ހުރުން."],"partOfSpeech":"ނަން"},"ޞޫފީން":{"definitions":["1. މުސްލިމުންގެ ތެރެއިން ދުންޔަވީ ކަންތައްތައް  ދޫކޮށް އަޅުކަމާ މަޝްޣޫލުވެ އުޅޭ ބައެއް."],"partOfSpeech":"ނަން"}}