{"ޢަރުޝި":{"definitions":["1. މާތް ރަސްކަލާނގެ އަރުޝި ފުޅު.","2. ތަޚުތު."],"partOfSpeech":"ނަން"},"ޢަމަލު":{"definitions":["1. ކުރާކަންތައް.","2. މަސައްކަތް."],"partOfSpeech":"ނަން"},"ޢަދުލަށްނިޔާކުރައްވާދުވަސް":{"definitions":["1. މަޝަރުދުވަސް."],"partOfSpeech":"ނަން"},"ޢަދުލު":{"definitions":["1. ކަންތައްކުރުމުގައި ބަހައްޓަށްވާ ހަމަގޮތް.","2. ފުރިހަމަގޮތް .","3. އިންސާފު.","4. އަނިޔާގެ  އިދިކޮޅު.","5. ނިޔާ."],"partOfSpeech":"ނަން"},"ޢަދުލުއިންޞާފު":{"definitions":["1. ހަމަހަމަ.","2. ޝަރީޢަތް."],"partOfSpeech":"ނަން"},"ޢަޒުމް":{"definitions":["1. ކަމެއްކުރުމަށް ޤަޞްދުކޮށް މާވަރުގަދައަށް ހިތުގައި  ކަނޑައަޅާ ކަނޑައެޅުން."],"partOfSpeech":"ނަން"},"ޢަޖުޒު":{"definitions":["1. ޅެންބައިތުގެ ދެވަނަކާފިޔާ."],"partOfSpeech":"ނަން"},"ޢާއިލާ":{"definitions":["1. ތިމާގެ މީހުން.","2. ދަރިކޮޅު.","3. ތިމާގެ މައްޗަށް އެމީހުންގެ ނަފަޤާތް ދިނުން  ވާޖިބުވާ މީހުން."],"partOfSpeech":"ނަން"},"ޢާލަމް":{"definitions":["1. ދުނިޔެ.","2. ހައްދަވާފައިވާހާ އެއްޗެއް."],"partOfSpeech":"ނަން"},"ޢާލިމް":{"definitions":["1. ޢިލްމުވެރިޔާ.","2. ޢިލްމު ދަންނަމީހާ."],"partOfSpeech":"ނަން"},"ޢީދުޞަލަވާތް":{"definitions":["1. ޢީދު ދުވަހު ކައްކައިގެން ކިޔަވާ ޞަލަވާތް.","2. މަޖާޒު: ދައުލަތުގެ ބައެއް ނޯކަރުންނަށް  ޢީދުޞަލަވާތަށް ކައްކާން ދެއްވާ ތަކެތި."],"partOfSpeech":"ނަން"},"ޢުމްރާ":{"definitions":["1. ޢަރަފާތުގައި ހުރުން މެނުވީ ޙައްޖާ އެއްގޮތަށްކުރާ  އަޅުކަމެއް"],"partOfSpeech":"ނަން"},"ޢުމްރާވުން":{"definitions":["1. ޢުމްރާގެ ރުކުންތަކާއި ސުންނަތްތައް އަދާކުރުން."],"partOfSpeech":"މަސްދަރު"}}