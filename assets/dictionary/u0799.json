{"ޙަނަފީމަޒުހަބު":{"definitions":["1. ސުންނަތް ޖަމާއަތުގެ އިމާމުންކުރެ އަލްއިމާމު  އަބޫޙަނީފާގެ ފިޤުހީގޮތުން އިޚުތިޔާރުކުރެއްވިގޮތް."],"partOfSpeech":"ނަން"},"ޙަނޫޠު":{"definitions":["1. މައްޔިތާ ކަފުން ކުރާއިރު ދެކަފުން ދެމެދަށް އަޅާ  މީރުވަސް ދުވާއެއްޗެއް. މިހަދަނީ ބޮކަރާއި ކެލާ  ގޭނުމަށްފަހު ބޮކަރު އަތަރާއި ކެލާއަތަރާއި ހުދުކާފޫރު  އެއްކޮށްގެންނެވެ."],"partOfSpeech":"ނަން"},"ޙަރަމު":{"definitions":["1. ހަށަންފުޅު."],"partOfSpeech":"ނަން"},"ޙަރަމްބަނުން":{"definitions":["1. ހަށަންބަނުން."],"partOfSpeech":"މަސްދަރު"},"ޙަރާމު":{"definitions":["1. ދީނީގޮތުން ހުއްދަނުވާނުވުން.","2. ދީނުގައި މަނާ ވާވުން."],"partOfSpeech":"ނަން"},"ޙަކީމު":{"definitions":["1. ބޭސްވެރިޔާ."],"partOfSpeech":"ނަން"},"ޙައުޟު":{"definitions":["1. ހަދައިފައި ހުންނަ ފެންގަނޑު."],"partOfSpeech":"ނަން"},"ޙައްލު":{"definitions":["1. ކަމެއް ހަމަޖައްސާ ޖެއްސުން."],"partOfSpeech":"ނަން"},"ޙައްލުކުރުން":{"definitions":["1. ކަމެއް ހަމަޖެއްސުން."],"partOfSpeech":"މަސްދަރު"},"ޙައްލުވުން":{"definitions":["1. ކަމެއް ހަމަޖެހުން."],"partOfSpeech":"މަސްދަރު"},"ޙައްޖަށްދިއުން":{"definitions":["1. ޙައްޖުގެ ފަރުޟު އަދާކުޅައުމަށް މައްކާއަށްދިއުން."],"partOfSpeech":"މަސްދަރު"},"ޙައްޖު":{"definitions":["1. ޙައްޖު.","2. އިސްލާމްދީނުގެ ފަސްވަނަ  ރުކުން."],"partOfSpeech":"ނަން"},"ޙައްޖުވުން":{"definitions":["1. ޙައްޖުގެ ފަރުޟުތައް އަދާކުރުން."],"partOfSpeech":"މަސްދަރު"},"ޙައްޖުމަސް":{"definitions":["1. ހަނދުމަހުގެ 12 ވަނަމަސް.","2. ހިޖުރީއަހަރު ނިމޭމަސް.","3. އެމަހެއްގައި ޙައްޖު  ދުވަސް ހިމެނޭމަސް."],"partOfSpeech":"ނަން"},"ޙައްޤު":{"definitions":["1. ތެދު.","2. އެމީހަކަށް ލިބެންޖެހޭ ޖެހުން.","3. މީހެއްގެ މިލްކު.","4. އަދްލު."],"partOfSpeech":"ނަން"},"ޙައްޤުވުން":{"definitions":["1. ކަމެއްކުރުން ވާޖިބުވުން.","2. ކަމަކަށް  އެކަށީގެންވުން.","3. އަމިއްލަވުން ނުވަތަ  މިލްކުވުން."],"partOfSpeech":"މަސްދަރު"},"ޙައްޤުވެރިން":{"definitions":["1. ޙައްޤު ލިބެންޖެހޭ މީހުން.","2. ޙައްޤު  ލިބިފައިވާ މީހުން."],"partOfSpeech":"ނަން"},"ޙައްޤުވެރިޔާ":{"definitions":["1. ޙައްޤު ލިބެންޖެހޭ މީހާ.","2. ޙައްޤު  ލިބިފައިވާ މީހާ."],"partOfSpeech":"ނަން"},"ޙަވާރީން":{"definitions":["1. ޢީސާޢަލައިހިއްސަލާމުގެ ޞަޙާބީން.  އެބޭކަލުންގެ އަދަދެއްކަމުގައި ބުނެވެނީ ބާރައެވެ.","2. މީހަކަށް ވަފާތެރިކަމާއެކު ޚިދްމަތްކުރާ މީހުން."],"partOfSpeech":"ނަން"},"ޙަމްދު":{"definitions":["1. ރިވެތި ތަޢުރީފާއިޘަނާ. މިބަސް ޚާއްޞަ  ވެފައިވަނީ ﷲގެ ޙަޟްރަތަށެވެ."],"partOfSpeech":"ނަން"},"ޙަމްދުކުރުން":{"definitions":["1. ރިވެތި ތަޢުރީފާ ޘަނާ މާތްﷲ އަށް  ދެންނެވުން."],"partOfSpeech":"މަސްދަރު"},"ޙަމްދުއެޅުން":{"definitions":["1. \" އަލްޙަމްދުﷲ\" އެވެ. ކިޔާފައި މޫނުގައި އަތް  ފިރުމައިލުން."],"partOfSpeech":"މަސްދަރު"},"ޙަފުލާ":{"definitions":["1. އުފާވެރި މުނާސަބަތެއް ފާހަގަކުރުމަށް،  މީހުންތަކެއް އެއްތަނަކަށް އެއްވާއެއްވުން.","2. އުފާވެރި މުނާސަބަތެއް ފާހަގަކުރުމަށް މީހުންތަކެއް  އެއްވެފައި ވާތަން.","3. އުފާވެރި  މުނާސަބަތެއްގައިކުރާ ޖަލްސާ."],"partOfSpeech":"ނަން"},"ޙަދަޘުވެރިޔާ":{"definitions":["1. ވުޟޫނެތްމީހާ.","2. ހިނެއިން  ވާޖިބުވެފައިވާ މީހާ."],"partOfSpeech":"ނަން"},"ޙަލާލު":{"definitions":["1. ޙަރާމްނޫން.","2. ޙަރާމްގެ އިދިކޮޅު.","3. ދީނުގައި ހުއްދަ."],"partOfSpeech":"ނަންއިތުރު"},"ޙަލްޤާ":{"definitions":["1. ކަރުތެރެ."],"partOfSpeech":"ނަން"},"ޙަސަބު":{"definitions":["1. ނަސަބު.","2. އާއިލާ."],"partOfSpeech":"ނަން"},"ޙަސަދަ":{"definitions":["1. މީހަކަށް ލިބުނުމޮޅު ކަމަކާމެދު ތިމާގެ  ހިތްދަތިވުމާއި އެމޮޅުކަމެއް ފިލައިދިއުމަށް އެދޭ  އެދުން.","2. ނއ. ދެކޮޅުވެރި."],"partOfSpeech":"ނަން"},"ޙަސަދަވެރި":{"definitions":["1. މީހަކަށް ލިބުނު މޮޅުކަމަކާމެދު  ތިމާހިތްދަތިވުމާއި އެމޮޅުކަމެއް ފިލައިދިއުމަށް އެދޭ.","2. ދެކޮޅުވެރިޔާ."],"partOfSpeech":"ނަންއިތުރު"},"ޙަސަދަވެރިކަން":{"definitions":["1. މީހަކަށް ލިބުނު މޮޅުކަމަކާމެދު  ތިމާހިތްދަތިވުމާއި އެމޮޅުކަމެއް ފިލައިދިއުމަށް  އެދޭކަން.","2. ދެކޮޅުވެރިކަން."],"partOfSpeech":"ނަންއިތުރުގެ ނަން"},"ޙަސަދަވެރިވުން":{"definitions":["1. މީހަކަށް ލިބުނު މޮޅުކަމަކާމެދު  ތިމާހިތްދަތިވުމާއި އެމޮޅުކަމެއް ފިލައިދިއުމަށް  އެދުން.","2. ދެކޮޅުވެރިވުން."],"partOfSpeech":"މަސްދަރު"},"ޙަސަދަވެރިޔާ":{"definitions":["1. މީހަކަށް ލިބުނު މޮޅުކަމަކާމެދު  ތިމާހިތްދަތިވުމާއި އެމޮޅުކަމެއް ފިލައިދިއުމަށް  އެދޭމީހާ.","2. ދެކޮޅުވެރިޔާ."],"partOfSpeech":"ނަން"},"ޙަޝަފަތު":{"definitions":["1. ޚިތާނުކުރުމުން ޒަކަރުން ފާޅުވާ ހިސާބު."],"partOfSpeech":"ނަން"},"ޙަޟާރަތު":{"definitions":["1. ރަނގަޅު ފެންވަރެއްގެ ދިރިއުޅުމަކަށް  ވާޞިލްވުމަށްޓަކައި އިންސާނާ އުފައްދާ  އުފެއްދުންތަކާއި ހޯދާ ހޯދުންތަކާއި ވިސްނާ  ވިސްނުންތަކާއި ޤުދުރަތީ މުއްސަނދިކަން  ބޭނުންކުރުމަށްޓަކައި ކުރާ މަސައްކަތްތައް."],"partOfSpeech":"ނަން"},"ޙަޤީޤަތް":{"definitions":["1. ކަންހުރިގޮތް.","2. ތެދު.","3. އޮޅުވައިލުމެއްނެތް."],"partOfSpeech":"ނަން"},"ޙާކިމު":{"definitions":["1. ވެރިމީހާ.","2. ނިޔާ ކަނޑައަޅާމީހާ."],"partOfSpeech":"ނަން"},"ޙާކިމުން":{"definitions":["1. އަމުރުވެރީން، ނިޔާއިއްވާމީހުން."],"partOfSpeech":"ނަން"},"ޙިލްމު":{"definitions":["1. ރުޅިމަޑުކަމާއި ކެތްތެރިކަން."],"partOfSpeech":"ނަން"},"ޙުރުމަތް":{"definitions":["1. ގަދަރާ ޢިއްޒަތް.","2. މާތްކަމާ  މަތިވެރިކަން.","3. ކަމޭހިތާ ކަމޭހިތުން."],"partOfSpeech":"ނަން"},"ޙުކުމް":{"definitions":["1. އަމުރު.","2. ނިޔާ."],"partOfSpeech":"ނަން"},"ޙުއްރިއްޔަތު":{"definitions":["1. މިނިވަންކަން.","2. އަޅުވެތިކަމަށްފަހު  ލިބޭ މިނިވަންކަން."],"partOfSpeech":"ނަން"},"ޙުދޫދު":{"definitions":["1. ދާއިރާ."],"partOfSpeech":"ނަން"},"ޙުޒާމު":{"definitions":["1. ރަސްކަމަސް ކޮލިލާ ދުވަހު ރަދުން ރަސްމީ  ހެދުންކޮޅު ތުރުކުރައްވާއިރު އަބާކޮޅުންގެ އެތެރޭން  ކަމަރުކޮޅުގެ ބަދަލުގައި ބަންނަވާ ފޮތިކޮޅި."],"partOfSpeech":"ނަން"},"ޙޫރުން":{"definitions":["1. ސުވަރުގެވަންތަ ވެރިންނަށް  ޚިދުމަތްކުރުމަށް ސުވަރުގޭގައި ތިބޭ ރީތި  އަންހެނުން.","2. އާދަޔާ ޚިލާފަށް ލޯރީތި  އަންހެނުން.","3. ޙޫރުލްޢީނުން."],"partOfSpeech":"ނަން"},"ޙޫތު":{"definitions":["1. ހަމްލުރާހީގެ އެންމެފަހުރާހި."],"partOfSpeech":"ނަން"}}