{"ޠަހޫރު":{"definitions":["1. އެހެން އެއްޗަކާ އެކުވެފައިނުވާ. މިއީ  ފެނާބެހޭގޮތުން ބޭނުންކުރާ ބަހެކެވެ."],"partOfSpeech":"ނަންއިތުރު"},"ޠަހޫރުކަން":{"definitions":["1. ފެން އެހެން އެއްޗަކާ އެކުވެފައި ނެތްކަން."],"partOfSpeech":"ނަންއިތުރުގެ ނަން"},"ޠަހޫރުފެން":{"definitions":["1. އެހެން އެއްޗަކާ އެކުވެފައިނުވާފެން."],"partOfSpeech":"ނަން"},"ޠަބީޢަތް":{"definitions":["1. އުފެދުމުގައި ލައްވައިފައިވާގޮތް. މިސާލު:  އަލިފާނުގެ ޠަބީޢަތް.","2. މިޒާޖު.","3. ޚަޞީލަތް.","4. ފިޠުރަތު."],"partOfSpeech":"ނަން"},"ޠަބީޢީ":{"definitions":["1. އުފެދުމުގައިހުރި.","2. ޠަބީޢަތުގެ."],"partOfSpeech":"ނަންއިތުރު"},"ޠަވާފުކުރުން":{"definitions":["1. ކަޢުބަތުﷲގެފުޅު ވަށައިގެން ހަތްފަހަރު  ހިނގުން.","2. މަޖާޒު: ތަނެއްގެ ވަށައިގެން  ބުރުޖެހުން."],"partOfSpeech":"މަސްދަރު"},"ޠާލިބާ":{"definitions":["1. ތަޢުލީމު ހޯދުމަށް މަސައްކަތްކުރާ އަންހެންކުއްޖާ."],"partOfSpeech":"ނަން"},"ޠާލިބު":{"definitions":["1. ތަޢުލީމު ހޯދުމަށް މަސައްކަތްކުރާ ފިރިހެންކުއްޖާ."],"partOfSpeech":"ނަން"},"ޠުހުރު":{"definitions":["1. ޠާހިރުކަމުގެ ދުވަސްވަރު.","2. ދެހައިޟު  ދެމެދު."],"partOfSpeech":"ނަން"},"ޠުލުސްމު":{"definitions":["1. ފުލޯކު ވާހަކައިގައި ކިޔާ ސިހުރުވެރިން  އުޅޭތަންތަން."],"partOfSpeech":"ނަން"}}